generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role: "APPLICANT" | "REVIEWER"
// ApplicationStatus: "DRAFT" | "SUBMITTED" | "IN_REVIEW" | "APPROVED" | "REJECTED" | "NEEDS_MORE_INFO"
// ExtractionStatus: "PENDING" | "PROCESSING" | "DONE" | "FAILED"
// EntityType: "INDIVIDUAL" | "COMPANY" | "TRUST" | "FUND" | "OTHER"
// ReviewActionType: "APPROVE" | "REJECT" | "REQUEST_INFO"

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          String    @default("APPLICANT")
  organization  String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  applications  Application[]
  reviewActions ReviewAction[]
  attestations  AttestationLog[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Application {
  id              String   @id @default(cuid())
  userId          String
  companyName     String?
  jurisdiction    String?
  registrationNum String?
  status          String   @default("DRAFT")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user              User              @relation(fields: [userId], references: [id])
  documents         Document[]
  extractedEntities ExtractedEntity[]
  orgStructures     OrgStructure[]
  reviewActions     ReviewAction[]
  attestations      AttestationLog[]
}

model Document {
  id               String   @id @default(cuid())
  applicationId    String
  fileName         String
  fileUrl          String
  fileType         String
  fileSize         Int
  extractionStatus String   @default("PENDING")
  extractedText    String?
  uploadedAt       DateTime @default(now())

  application       Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  extractedEntities ExtractedEntity[]
}

model ExtractedEntity {
  id             String   @id @default(cuid())
  documentId     String
  applicationId  String
  entityName     String
  entityType     String
  ownershipPct   Float?
  parentEntityId String?
  sourceText     String?
  sourcePageNum  Int?
  confidence     Float    @default(0)
  isUbo          Boolean  @default(false)
  createdAt      DateTime @default(now())

  document      Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  application   Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  parentEntity  ExtractedEntity? @relation("EntityHierarchy", fields: [parentEntityId], references: [id])
  childEntities ExtractedEntity[] @relation("EntityHierarchy")
}

model OrgStructure {
  id            String   @id @default(cuid())
  applicationId String
  structureJson String
  version       Int      @default(1)
  generatedAt   DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model ReviewAction {
  id            String   @id @default(cuid())
  applicationId String
  reviewerId    String
  action        String
  notes         String?
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewer    User        @relation(fields: [reviewerId], references: [id])
}

model AttestationLog {
  id            String   @id @default(cuid())
  applicationId String
  userId        String
  attestedAt    DateTime @default(now())
  ipAddress     String?
  statement     String

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])
}
